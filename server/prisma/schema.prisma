generator client {
  provider = "prisma-client-js"
}

// ALVO DE PRODUÇÃO: PostgreSQL. Trocar `provider` para "postgresql" e ajustar
// DATABASE_URL quando o Postgres estiver disponível (Docker ou nativo).
// Em dev local sem infra, usamos SQLite (arquivo prisma/dev.db).
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Turma do TG (T1..T4). Cada turma tira sua semana de guarda em rodízio (ordem).
model Turma {
  id        String   @id @default(cuid())
  codigo    String   @unique // "T1".."T4"
  apelido   String // "Caveira", "Pantera", ...
  ordem     Int      @unique // 1..4 — sequência do rodízio
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  people      Person[]
  users       User[]
  schedules   Schedule[]
  attendances Attendance[]
  missions    Mission[]
}

/// Efetivo: monitores (isMonitor=true) e guardas gerais.
/// A identidade é sempre (num + nome) — o nº 229 existe em dois registros.
model Person {
  id        String   @id @default(cuid())
  num       String
  nome      String
  isMonitor Boolean  @default(false)
  active    Boolean  @default(true) // pertence ao efetivo (soft-delete quando false)
  available Boolean  @default(true) // disponível p/ escala (false = doente/afastado)
  createdAt DateTime @default(now())

  // Guardas pertencem a uma turma; monitores (TG-wide) ficam sem turma.
  turmaId String?
  turma   Turma?  @relation(fields: [turmaId], references: [id], onDelete: SetNull)

  assignments Assignment[]
  attendances Attendance[]
  missions    Mission[]

  @@unique([num, nome])
  @@index([isMonitor])
  @@index([turmaId])
}

/// Usuários de acesso ao sistema (login). Senha guardada com hash (scrypt).
/// role: "superadmin" (Comandante do TG) | "instrutor" (Sgt de uma turma).
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("instrutor")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  // Instrutor pertence a uma turma; superadmin pode ter (Mario = T3) ou não.
  turmaId String?
  turma   Turma?  @relation(fields: [turmaId], references: [id], onDelete: SetNull)

  @@index([turmaId])
}

/// Instrutores de Sobreaviso (SGTs) — escolhidos por dia no aditamento.
model Instructor {
  id        String   @id @default(cuid())
  nome      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

/// Configuração (linha única) dos textos fixos do Aditamento.
model AditamentoConfig {
  id              String   @id @default("singleton")
  tg              String   @default("05-003")
  cidade          String   @default("Londrina-PR")
  numero          String   @default("002")
  uniforme        String   @default("9º C2")
  assinante       String   @default("MARIO ALESSANDRO GOMES HENRIQUE")
  posto           String   @default("S Ten")
  funcaoAssinante String   @default("Chefe da Instrução do TG 05-003")
  lema            String   @default("160 ANOS DA BATALHA DE TUIUTÍ: A BATALHA DOS PATRONOS!")
  updatedAt       DateTime @updatedAt
}

/// Histórico manual importado (planilha/CSV das guardas feitas à mão).
/// Soma-se ao histórico calculado das escalas salvas para balancear o sorteio.
model ManualHistory {
  id        String   @id @default(cuid())
  num       String
  nome      String
  guardas   Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([num, nome])
}

/// Saldo inicial de horas de serviço (FICHA importada), por pessoa e mês (1..12).
/// Somado às horas calculadas das escalas FECHADAS no relatório de horas.
model ManualHours {
  id    String @id @default(cuid())
  num   String
  nome  String
  mes   Int // 1..12
  horas Int    @default(0)

  @@unique([num, nome, mes])
}

/// Uma escala gerada (terça → segunda, 7 dias). Pertence a uma turma (a que
/// está de semana no rodízio).
model Schedule {
  id        String    @id @default(cuid())
  startDate DateTime // terça inicial (00:00)
  createdAt DateTime  @default(now())
  status    String    @default("ABERTA") // "ABERTA" | "FECHADA"
  closedAt  DateTime?

  turmaId String?
  turma   Turma?  @relation(fields: [turmaId], references: [id], onDelete: SetNull)

  assignments Assignment[]

  @@index([startDate])
  @@index([turmaId])
}

/// Cada vaga preenchida em um dia/função/slot de uma escala.
model Assignment {
  id         String   @id @default(cuid())
  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  dayIndex Int // 0..6 (0 = terça)
  funcao   String
  slot     Int // posição da vaga dentro da função

  // snapshot do nome/num + vínculo opcional ao Person (pode ser VAZIO)
  personId   String?
  person     Person? @relation(fields: [personId], references: [id], onDelete: SetNull)
  personNum  String
  personNome String

  @@unique([scheduleId, dayIndex, funcao, slot])
  @@index([scheduleId])
}

/// Presença na instrução da manhã (independente da guarda). 1 registro por pessoa/dia.
/// status: "PRESENTE" | "FALTA" | "JUSTIFICADO". Identidade por (num, nome).
model Attendance {
  id         String   @id @default(cuid())
  date       DateTime // dia da instrução, normalizado 00:00
  status     String   @default("PRESENTE")
  createdAt  DateTime @default(now())

  turmaId String?
  turma   Turma?  @relation(fields: [turmaId], references: [id], onDelete: SetNull)

  personId   String?
  person     Person? @relation(fields: [personId], references: [id], onDelete: SetNull)
  personNum  String
  personNome String

  @@unique([date, personNum, personNome])
  @@index([turmaId, date])
}

/// Horas complementares (missões). Horas variáveis (Float). Lançadas manual/CSV.
/// O relatório soma por pessoa e compara com a meta (MissaoConfig).
model Mission {
  id        String    @id @default(cuid())
  date      DateTime?
  descricao String
  horas     Float     @default(0)
  createdAt DateTime  @default(now())

  turmaId String?
  turma   Turma?  @relation(fields: [turmaId], references: [id], onDelete: SetNull)

  personId   String?
  person     Person? @relation(fields: [personId], references: [id], onDelete: SetNull)
  personNum  String
  personNome String

  @@index([turmaId])
}

/// Config (linha única) da meta de horas complementares (ajustável pelo Comandante).
model MissaoConfig {
  id        String   @id @default("singleton")
  metaHoras Int      @default(60)
  updatedAt DateTime @updatedAt
}

/// Trilha de auditoria: registra cada ação de escrita (quem, o quê, quando).
/// Snapshot do usuário (username/role/turma) p/ o log sobreviver à remoção da conta.
model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Quem fez (snapshot — sem FK, para o log nunca sumir/quebrar).
  userId   String?
  username String  @default("?")
  role     String  @default("?")
  turmaId  String?

  acao    String // rótulo amigável: "Gerou escala", "Criou usuário", ...
  method  String // POST | PUT | PATCH | DELETE
  rota    String // caminho normalizado: /api/schedule/:id
  status  Int // status HTTP da resposta
  alvoId  String? // id do registro afetado (quando há :id na rota)
  detalhe String? // resumo de campos seguros do corpo (sem senhas)

  @@index([createdAt])
  @@index([userId])
}
