{
  "name": "sysguarda-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "prod:schema": "node prisma/genProdSchema.mjs",
    "prod:db": "node prisma/genProdSchema.mjs && prisma generate --schema prisma/schema.production.prisma && prisma db push --schema prisma/schema.production.prisma",
    "prod:seed": "tsx prisma/seed.ts && tsx prisma/updateRoster.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
