# ===== Banco de dados =====
# DEV local (sem infra): SQLite
DATABASE_URL="file:./dev.db"
# PRODUÇÃO (VPS): PostgreSQL — descomente e ajuste
# DATABASE_URL="postgresql://sysguarda:senha_forte@localhost:5432/sysguarda?schema=public"

# ===== Servidor =====
PORT=3333
# Em produção, defina como "production" para o Express servir o frontend
NODE_ENV=development

# ===== Login (HTTP Basic Auth) =====
# Se APP_PASSWORD estiver vazio, o app fica ABERTO (ok em dev).
# Em produção, defina uma senha forte para proteger todo o app.
APP_USER=admin
APP_PASSWORD=
# Segredo para assinar a sessão (cookie). Se vazio, deriva de APP_PASSWORD.
# Defina um valor aleatório longo em produção (ex.: openssl rand -hex 32).
APP_SECRET=

# Opcional: caminho do frontend compilado (default: ../client/dist)
# CLIENT_DIST=/var/www/sysguarda/client/dist
